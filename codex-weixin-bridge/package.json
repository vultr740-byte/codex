{
  "name": "codex-weixin-bridge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Bridge Weixin long-poll delivery to a Codex app-server WebSocket thread runtime.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "tsx src/index.ts",
    "test": "node --test --import tsx test/**/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "ws": "^8.18.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.20.6",
    "typescript": "^5.8.3"
  }
}
